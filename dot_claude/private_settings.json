{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/akshaybapat/.claude/hooks/orchestration_reminder.py"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/akshaybapat/.claude/hooks/subagent_start_context.py"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /home/akshaybapat/.claude/statusline-command.sh",
    "refreshInterval": 30
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true,
    "claude-mem@thedotmack": true
  },
  "extraKnownMarketplaces": {
    "omc": {
      "source": {
        "source": "directory",
        "path": "/home/akshaybapat/.local/share/oh-my-claudecode"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true
}
