#!/usr/bin/env bash
# doctor — health check for omarchy-personal. Reports state of the stack.
# Run from anywhere; locates chezmoi source via `chezmoi source-path`.
#
# Usage: doctor [--json]
#   --json   Emit machine-readable JSON (suppresses color output)

set -u

# --- argument parsing ---
JSON_MODE=false
for arg in "$@"; do
  case "$arg" in
    --json) JSON_MODE=true ;;
    *) echo "Unknown argument: $arg" >&2; exit 1 ;;
  esac
done

# --- color helpers (suppressed in JSON mode) ---
if $JSON_MODE; then
  GREEN=""; RED=""; YELLOW=""; BLUE=""; NC=""
else
  GREEN=$'\033[1;32m'; RED=$'\033[1;31m'; YELLOW=$'\033[1;33m'; BLUE=$'\033[1;34m'; NC=$'\033[0m'
fi

ok()     { printf '%s✓%s %s\n' "$GREEN" "$NC" "$*"; }
fail()   { printf '%s✗%s %s\n' "$RED"   "$NC" "$*"; }
warn()   { printf '%s!%s %s\n' "$YELLOW" "$NC" "$*"; }
header() { printf '\n%s== %s ==%s\n' "$BLUE" "$*" "$NC"; }

# --- JSON accumulation ---
# Structure: associative array section → json-fragment lines
declare -A _JSON_SECTIONS
_current_section=""

_json_record() {
  # _json_record <section> <check_key> <status: pass|warn|fail> <message>
  local section="$1" key="$2" status="$3" msg="$4"
  local escaped_msg
  escaped_msg=$(printf '%s' "$msg" | sed 's/\\/\\\\/g; s/"/\\"/g')
  local entry="    \"${key}\": {\"status\": \"${status}\", \"message\": \"${escaped_msg}\"}"
  if [[ -v "_JSON_SECTIONS[$section]" ]]; then
    _JSON_SECTIONS["$section"]+=$'\n'"${entry},"
  else
    _JSON_SECTIONS["$section"]="${entry},"
  fi
}

_emit_json() {
  printf '{\n'
  local first_section=true
  for section in "${!_JSON_SECTIONS[@]}"; do
    $first_section || printf ',\n'
    first_section=false
    local body="${_JSON_SECTIONS[$section]}"
    # strip trailing comma from last entry
    body="${body%,}"
    printf '  "%s": {\n%s\n  }' "$section" "$body"
  done
  printf '\n}\n'
}

# Wrappers that record to JSON AND print in non-JSON mode
rok()   {
  local sec="$1" key="$2" msg="$3"
  _json_record "$sec" "$key" "pass" "$msg"
  $JSON_MODE || ok "$msg"
}
rfail() {
  local sec="$1" key="$2" msg="$3"
  _json_record "$sec" "$key" "fail" "$msg"
  $JSON_MODE || fail "$msg"
}
rwarn() {
  local sec="$1" key="$2" msg="$3"
  _json_record "$sec" "$key" "warn" "$msg"
  $JSON_MODE || warn "$msg"
}
rheader() {
  $JSON_MODE || header "$*"
}

# ── Core tooling ──────────────────────────────────────────────────────────────
rheader "Core tooling"
for t in chezmoi paru pacman git gh op age metapac mise; do
  if command -v "$t" >/dev/null 2>&1; then
    rok "core" "$t" "$t: $(command -v "$t")"
  else
    rfail "core" "$t" "$t: not on PATH"
  fi
done

# ── chezmoi state ─────────────────────────────────────────────────────────────
rheader "chezmoi"
if command -v chezmoi >/dev/null 2>&1; then
  SRC=$(chezmoi source-path 2>/dev/null || echo "")
  if [ -n "$SRC" ] && [ -d "$SRC" ]; then
    rok "chezmoi" "source_path" "source path: $SRC"
  else
    rfail "chezmoi" "source_path" "source path resolves to nothing"
  fi
  DIFF=$(chezmoi diff 2>&1 | wc -l)
  if [ "$DIFF" -eq 0 ]; then
    rok "chezmoi" "diff" "diff: clean (no pending changes)"
  else
    rwarn "chezmoi" "diff" "diff: $DIFF lines of pending changes (run: chezmoi diff)"
  fi
fi

# ── metapac state ─────────────────────────────────────────────────────────────
rheader "metapac"
if command -v metapac >/dev/null 2>&1 && [ -f "$HOME/.local/share/chezmoi/metapac/metapac.toml" ]; then
  cd "$HOME/.local/share/chezmoi/metapac" || true
  MISSING=$(metapac unmanaged --config metapac.toml 2>/dev/null | wc -l)
  rok "metapac" "config" "metapac config present"
  if [ "$MISSING" -eq 0 ]; then
    rok "metapac" "drift" "drift: 0 unmanaged packages"
  else
    rwarn "metapac" "drift" "drift: $MISSING unmanaged pkgs (consider adding to a group)"
  fi
else
  rwarn "metapac" "config" "metapac not configured yet"
fi

# ── systemd user services ─────────────────────────────────────────────────────
rheader "systemd user services"
EXPECTED=(aether-bg-watcher espanso fusuma mpd mpd-mpris rinertia wireplumber)
for s in "${EXPECTED[@]}"; do
  if systemctl --user is-enabled "$s.service" >/dev/null 2>&1; then
    rok "systemd" "$s" "$s.service enabled"
  else
    rwarn "systemd" "$s" "$s.service not enabled"
  fi
done

# ── omarchy theme ─────────────────────────────────────────────────────────────
rheader "omarchy theme"
if [ -L "$HOME/.config/omarchy/current/theme" ]; then
  THEME=$(basename "$(readlink "$HOME/.config/omarchy/current/theme")")
  rok "theme" "active" "active theme: $THEME"
else
  rwarn "theme" "active" "no active theme symlink at ~/.config/omarchy/current/theme"
fi

# ── fonts ─────────────────────────────────────────────────────────────────────
rheader "fonts"
if fc-list 2>/dev/null | grep -qi "JetBrainsMono Nerd"; then
  rok "fonts" "jetbrains_mono" "JetBrainsMono Nerd Font installed"
else
  rfail "fonts" "jetbrains_mono" "JetBrainsMono Nerd Font missing"
fi
if fc-list 2>/dev/null | grep -qi "Inter Variable"; then
  rok "fonts" "inter" "Inter installed"
else
  rwarn "fonts" "inter" "Inter font missing (cosmetic — UI falls back to system sans)"
fi

# ── GitHub CLI ────────────────────────────────────────────────────────────────
rheader "GitHub CLI"
if command -v gh >/dev/null 2>&1; then
  if gh auth status >/dev/null 2>&1; then
    GH_USER=$(gh api user --jq .login 2>/dev/null || echo unknown)
    rok "github" "auth" "gh CLI authenticated as: $GH_USER"
  else
    rwarn "github" "auth" "gh CLI not authenticated — run: gh auth login"
  fi
fi

# ── 1Password ─────────────────────────────────────────────────────────────────
rheader "1Password CLI"
if command -v op >/dev/null 2>&1; then
  if op whoami >/dev/null 2>&1; then
    OP_WHO=$(op whoami 2>/dev/null | grep -oE '@.*' | head -1)
    rok "onepassword" "auth" "op signed in as: $OP_WHO"
  else
    rwarn "onepassword" "auth" "op not signed in — run: eval \$(op signin)"
  fi
fi

# ── ai-config external ────────────────────────────────────────────────────────
rheader "ai-config external"
if [ -d "$HOME/.local/share/ai-config/.git" ]; then
  rok "ai_config" "present" "ai-config present"
  cd "$HOME/.local/share/ai-config" && \
    (git fetch --quiet 2>/dev/null
     HEAD=$(git rev-parse --short HEAD)
     UP=$(git rev-parse --short origin/main 2>/dev/null || git rev-parse --short origin/master 2>/dev/null)
     rok "ai_config" "rev" "head: $HEAD origin: ${UP:-?}")
else
  rwarn "ai_config" "present" "ai-config not present at ~/.local/share/ai-config (will be pulled by chezmoi external)"
fi

# ── ISO age ───────────────────────────────────────────────────────────────────
rheader "ISO"
if command -v gh >/dev/null 2>&1 && gh auth status >/dev/null 2>&1; then
  ISO_DATE=$(gh release list \
    -R akshaybapat6365/omarchy-personal \
    --limit 1 \
    --json publishedAt \
    --jq '.[0].publishedAt' 2>/dev/null || echo "")
  if [ -z "$ISO_DATE" ]; then
    rwarn "iso" "age" "could not fetch latest ISO release date"
  else
    # compute age in days using python3 (portable, no GNU date needed)
    AGE_DAYS=$(python3 -c "
from datetime import datetime, timezone
pub = datetime.fromisoformat('${ISO_DATE}'.replace('Z','+00:00'))
now = datetime.now(timezone.utc)
print((now - pub).days)
" 2>/dev/null || echo "")
    if [ -z "$AGE_DAYS" ]; then
      rwarn "iso" "age" "could not parse ISO release date: $ISO_DATE"
    elif [ "$AGE_DAYS" -gt 30 ]; then
      rwarn "iso" "age" "latest ISO is ${AGE_DAYS}d old (published: $ISO_DATE) — consider rebuilding"
    else
      rok "iso" "age" "latest ISO is ${AGE_DAYS}d old (published: $ISO_DATE)"
    fi
  fi
else
  rwarn "iso" "age" "gh CLI unavailable or not authenticated — skipping ISO age check"
fi

# ── metapac drift (dedicated section) ────────────────────────────────────────
rheader "metapac drift"
if command -v metapac >/dev/null 2>&1 && [ -f "$HOME/.local/share/chezmoi/metapac/metapac.toml" ]; then
  cd "$HOME/.local/share/chezmoi/metapac" || true
  DRIFT_COUNT=$(metapac unmanaged --config metapac.toml 2>/dev/null | wc -l)
  if [ "$DRIFT_COUNT" -eq 0 ]; then
    rok "metapac_drift" "count" "0 unmanaged packages — fully tracked"
  else
    rwarn "metapac_drift" "count" "${DRIFT_COUNT} unmanaged packages not in any metapac group"
  fi
else
  rwarn "metapac_drift" "count" "metapac unavailable — cannot measure drift"
fi

# ── emit JSON or done ─────────────────────────────────────────────────────────
if $JSON_MODE; then
  _emit_json
else
  echo ""
  echo "Done."
fi
