# Files in the source tree that should NOT land in $HOME on `chezmoi apply`.
README.md
LICENSE
bootstrap.sh
doctor
docs/
.github/
.editorconfig

# metapac/ is a sidecar config for the metapac tool, not a $HOME target.
# Lives in the source tree only; consumed by run_once_after_01-metapac-sync.sh.
metapac
metapac/**

# Per-machine: skip macOS-specific (we're on Linux/Arch)
{{ if ne .chezmoi.os "linux" -}}
dot_config/hypr
dot_config/waybar
dot_config/walker
dot_config/mako
{{- end }}

# State / cache files that may end up inside config dirs
**/node_modules/**
**/.cache/**
**/cache/**
**/*.log
**/*.bak
**/*.tmp
**/tasks/**
**/sessions/**

# Editor/IDE local state
**/.idea/**
**/.vscode/**

# Browser/runtime state (in case it sneaks in)
**/Cookies
**/Cookies-journal
**/History
**/History-journal

# Secrets / API keys — now encrypted via age (see docs/secrets.md)

# Symlinks whose absolute targets won't exist on a fresh machine until pkg installers run
dot_local/bin/symlink_agent-browser
dot_local/bin/symlink_hermes
dot_local/bin/symlink_cmonitor
dot_local/bin/symlink_ccmonitor
dot_local/bin/symlink_cava
dot_local/bin/symlink_brave

# ai-config-owned dirs (managed via .chezmoiexternal.toml → akshaybapat6365/ai-config).
# NOTE: dot_claude/ is intentionally tracked here (commit c17f5fd) for OMC hooks
# + statusline + CLAUDE.md symlink that pair with this user's specific overlay,
# distinct from ai-config's claude/ tree. Do NOT add dot_claude to ignores.
dot_codex
dot_codex/**
dot_cursor
dot_cursor/**
dot_gemini
dot_gemini/**
dot_cline
dot_cline/**
# dot_local/share/trackpad-tuner is tracked (commit c17f5fd). Other subdirs in
# dot_local/share/ should also be allowed; nothing else lives there yet.

# Runtime sockets / PID files / transient state that sometimes lives in ~/.config
**/*.sock
**/*.sock.pid
**/*.pid
**/cliamp/*
**/private_ibus/**
