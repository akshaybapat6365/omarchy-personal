# play <song name> — stream first YouTube hit as audio in mpv
play() { mpv --no-video --ytdl-format=bestaudio "ytdl://ytsearch1:$*"; }
# pick <song name> — show top 5 hits, use > / < to skip
pick() { mpv --no-video --ytdl-format=bestaudio "ytdl://ytsearch5:$*"; }

# Atuin: fuzzy-search shell history (↑ key opens fullscreen search)
eval "$(atuin init bash)"

# Yazi: `y` opens the file manager and cd's into the dir you exit at
y() {
    local tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
    yazi "$@" --cwd-file="$tmp"
    if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
        builtin cd -- "$cwd"
    fi
    rm -f -- "$tmp"
}

