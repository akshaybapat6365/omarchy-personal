#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="$HOME/.local/state/music-ui"
TUI_ADDR_FILE="$STATE_DIR/tui_address"
AUTH_REFRESH_HELPER="$HOME/.local/bin/ytm-auth-refresh"

load_tui_address() {
    if [[ -f "$TUI_ADDR_FILE" ]]; then
        head -n 1 "$TUI_ADDR_FILE"
    fi
}

store_tui_address() {
    mkdir -p "$STATE_DIR"
    printf '%s\n' "$1" > "$TUI_ADDR_FILE"
}

clear_tui_address() {
    rm -f "$TUI_ADDR_FILE"
}

find_tui_window_address() {
    command -v hyprctl >/dev/null 2>&1 || return 1
    command -v jq >/dev/null 2>&1 || return 1
    hyprctl clients -j 2>/dev/null \
        | jq -r '
            .[]
            | select(
                .class == "org.omarchy.music-tui"
                or .class == "org.omarchy.music"
            )
            | .address
        ' 2>/dev/null \
        | head -n 1
}

window_exists_by_address() {
    local addr="$1"
    [[ -n "$addr" ]] || return 1
    command -v hyprctl >/dev/null 2>&1 || return 1
    command -v jq >/dev/null 2>&1 || return 1
    hyprctl clients -j 2>/dev/null | jq -e --arg a "$addr" '.[] | select(.address == $a)' >/dev/null
}

focus_tui() {
    local addr
    addr="$(load_tui_address)"
    if window_exists_by_address "$addr"; then
        hyprctl dispatch focuswindow "address:$addr" >/dev/null 2>&1 || return 1
        return 0
    fi
    addr="$(find_tui_window_address)"
    if window_exists_by_address "$addr"; then
        store_tui_address "$addr"
        hyprctl dispatch focuswindow "address:$addr" >/dev/null 2>&1 || return 1
        return 0
    fi
    clear_tui_address
    return 1
}

"$AUTH_REFRESH_HELPER" >/dev/null 2>&1 || true

focus_tui
