#!/usr/bin/env bash
# clipboard-smart {copy|paste} — universal copy/paste via keystroke synthesis.
#
# v4 (2026-05-19): replaced the PRIMARY-only terminal copy path with proper
# Ctrl+Shift+C / Ctrl+Shift+V keystroke synthesis. The previous design relied
# on the user mouse-selecting text first; keyboard-only flows silently failed.
#
# Routes:
#   copy  in terminal  → hyprctl sendshortcut CTRL+SHIFT+C (kitty/ghostty/
#                        alacritty/foot/wezterm all bind this to copy-selection)
#                        + bridge PRIMARY→CLIPBOARD as a safety net if Ctrl+
#                        Shift+C didn't update clipboard (e.g. no selection).
#   copy  non-terminal → hyprctl sendshortcut CTRL+C (universal).
#   paste in terminal  → hyprctl sendshortcut CTRL+SHIFT+V.
#   paste non-terminal → hyprctl sendshortcut CTRL+V.
#
# A 90 ms sleep before the synthesized keystroke lets the user's held Super
# release first so the app doesn't see Super+Ctrl+Shift+C.
#
# Instrumented to /tmp/desktop-debug.log on every invocation.

set -uo pipefail
LOG=/tmp/desktop-debug.log
ts() { date +'%H:%M:%S.%3N'; }
log() { printf '[%s] clipboard-smart %s\n' "$(ts)" "$*" >> "$LOG"; }

mode="${1:-}"
[[ -z "$mode" ]] && { log "ERROR: no mode arg"; echo "usage: clipboard-smart {copy|paste}" >&2; exit 1; }
log "v4 START mode=$mode pid=$$"

raw_class=$(hyprctl activewindow -j 2>>"$LOG" | jq -r '.class // ""' 2>>"$LOG")
class=$(printf '%s' "$raw_class" | tr '[:upper:]' '[:lower:]')
log "active.class='$raw_class' (lower='$class')"

is_terminal=0
case "$class" in
    *ghostty*|alacritty|kitty|wezterm|foot|com.mitchellh.ghostty|org.alacritty)
        is_terminal=1 ;;
    ai-claude|ai-codex|ai-opencode|ai-hermes|ai-monitor|ai-ccusage|ai-skill-picker|ask-overlay)
        is_terminal=1 ;;
esac
log "is_terminal=$is_terminal"

# Wait for the user's held Super key to release before we synthesize keystrokes
# with modifiers. 90 ms is conservative; faster typists may need less.
sleep 0.09

case "$mode" in
    copy)
        if (( is_terminal )); then
            # Capture clipboard state before our keystroke so we can detect whether
            # Ctrl+Shift+C actually updated it.
            before=$(wl-paste --no-newline 2>>"$LOG" || true)

            log "RUN sendshortcut CTRL SHIFT, C (terminal)"
            hyprctl dispatch sendshortcut "CTRL SHIFT, C," >>"$LOG" 2>&1
            rc=$?

            # Give the terminal/wl-clipboard a moment to commit the new content.
            sleep 0.07

            after=$(wl-paste --no-newline 2>>"$LOG" || true)
            primary=$(wl-paste --primary --no-newline 2>>"$LOG" || true)

            # If clipboard didn't change but PRIMARY has fresh content, bridge it.
            # This covers terminals where Ctrl+Shift+C had no selection to copy
            # but the user did mouse-select something (PRIMARY-only).
            if [[ "$after" == "$before" && -n "$primary" && "$primary" != "$before" ]]; then
                printf '%s' "$primary" | wl-copy
                rc=$?
                log "fallback bridge: PRIMARY → CLIPBOARD (${#primary} bytes)"
                after=$primary
            fi

            bytes=${#after}
            if [[ -n "$after" ]]; then
                notify-send -t 700 "Copied" "$bytes chars" 2>/dev/null
            else
                notify-send -t 1500 "Copy" "Nothing to copy — select text first" 2>/dev/null
            fi
            log "copy rc=$rc bytes=$bytes"
        else
            log "RUN sendshortcut CTRL, C (non-terminal)"
            hyprctl dispatch sendshortcut "CTRL, C," >>"$LOG" 2>&1
            rc=$?
            sleep 0.05
            bytes=$(wl-paste --no-newline 2>>"$LOG" | wc -c)
            notify-send -t 700 "Copied" "${bytes} chars" 2>/dev/null
            log "copy rc=$rc bytes=$bytes"
        fi
        ;;

    paste)
        bytes=$(wl-paste --no-newline 2>>"$LOG" | wc -c)
        if (( bytes == 0 )); then
            log "NO-OP: clipboard empty"
            notify-send -t 1500 "Paste" "Clipboard is empty" 2>/dev/null
            rc=0
        elif (( is_terminal )); then
            log "RUN sendshortcut CTRL SHIFT, V (terminal, $bytes bytes pending)"
            hyprctl dispatch sendshortcut "CTRL SHIFT, V," >>"$LOG" 2>&1
            rc=$?
            notify-send -t 700 "Pasted" "$bytes chars" 2>/dev/null
        else
            log "RUN sendshortcut CTRL, V (non-terminal, $bytes bytes pending)"
            hyprctl dispatch sendshortcut "CTRL, V," >>"$LOG" 2>&1
            rc=$?
            notify-send -t 700 "Pasted" "$bytes chars" 2>/dev/null
        fi
        log "paste rc=$rc"
        ;;

    *)
        log "ERROR: unknown mode '$mode'"
        echo "usage: clipboard-smart {copy|paste}" >&2; exit 1 ;;
esac

log "END mode=$mode rc=$rc"
exit "$rc"
