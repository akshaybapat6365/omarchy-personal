#!/usr/bin/env bash
# omarchy-spend-notify — fire a Mako notification when budget_used_pct >= 0.85
# Invoked as ExecStartPost by omarchy-spend-prefetch.service

STATE_FILE="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/omarchy-spend/state.json"
[ -f "$STATE_FILE" ] || exit 0

PCT=$(jq -r '.aggregates.budget_used_pct // 0' "$STATE_FILE" 2>/dev/null)
[ -z "$PCT" ] && exit 0

OVER=$(echo "$PCT >= 0.85" | bc -l 2>/dev/null)
[ "$OVER" = "1" ] || exit 0

PCT_DISPLAY=$(echo "$PCT * 100" | bc -l | xargs printf "%.0f")
notify-send -a omarchy-spend -u critical "Budget threshold reached" "${PCT_DISPLAY}% of daily budget used"
