#!/usr/bin/env bash
# Trackpad calibration game launcher.
# Starts a local HTTP server with the calibration UI, opens the browser,
# and reverts any live curve changes via `hyprctl reload` on exit.
set -euo pipefail

PORT="${TRACKPAD_TUNE_PORT:-38483}"
SRC_DIR="$HOME/.local/share/trackpad-tuner"

cleanup() {
  echo ""
  echo "Reverting any live curve changes to file defaults..."
  hyprctl reload >/dev/null 2>&1 || true
  if [[ -n "${SERVER_PID:-}" ]]; then
    kill "$SERVER_PID" 2>/dev/null || true
  fi
  exit 0
}
trap cleanup INT TERM EXIT

echo "Starting trackpad-tuner on http://127.0.0.1:$PORT ..."
cd "$SRC_DIR"
python3 server.py --port "$PORT" &
SERVER_PID=$!
sleep 0.4

echo "Opening browser..."
xdg-open "http://127.0.0.1:$PORT/" >/dev/null 2>&1 &

echo ""
echo "Tool running. Ctrl+C here to quit (auto-reverts curve)."
echo ""
wait "$SERVER_PID"
