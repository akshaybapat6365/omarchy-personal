#!/usr/bin/env bash
# macos-overview — macOS-style 3-finger up/down gesture handler.
#
# Usage:  macos-overview up | macos-overview down
#
# up:   toggle Mission Control. Resolution order:
#         1. quickshell-overview daemon (`qs -c overview`) if running —
#            visual workspace overview with live window thumbnails,
#            drag-and-drop, glass effects. The primary path since
#            installing quickshell-overview-git on 2026-05-21.
#         2. hyprexpo plugin if loaded — historic primary, blocked
#            upstream until Arch ships hyprland 0.54.3-5.
#         3. omarchy-window-switcher (text list via walker dmenu) —
#            emergency fallback only.
# down: if hyprexpo overview is open, dismiss it. Otherwise toggle
#       scratchpad (App Exposé approximation).
#
# Bound from:
#   ~/.config/hypr/input.conf   gesture = 3, up   -> macos-overview up
#                               gesture = 3, down -> macos-overview down
#                               gesture = 4, up   -> macos-overview up
#
# State lives in /tmp/mc-overview-state. The hyprexpo dispatcher exposes
# `on`/`off`/`toggle`; `on`/`off` are idempotent at the plugin level so
# even if our state drifts (e.g. someone toggles via keybind that bypasses
# this wrapper), one gesture re-syncs everything.
#
# Instrumentation: appends to /tmp/desktop-debug.log on every invocation.

set -uo pipefail
LOG=/tmp/desktop-debug.log
STATE=/tmp/mc-overview-state
ts() { date +'%H:%M:%S.%3N'; }
log() { printf '[%s] macos-overview %s\n' "$(ts)" "$*" >> "$LOG"; }

dir="${1:-up}"
log "START pid=$$ dir=$dir"

# PRIMARY: quickshell-overview daemon. Installed 2026-05-21, supersedes
# the old walker-dmenu emergency fallback. Detection: pgrep for the
# daemon's command line (`qs -c overview`).
if pgrep -f 'qs -c overview' >/dev/null 2>&1; then
    case "$dir" in
        up)
            log "qs-overview daemon detected on UP -> qs-overview toggle"
            exec qs-overview toggle
            ;;
        down)
            log "qs-overview daemon detected on DOWN -> qs-overview toggle"
            # Same daemon — toggle either opens or closes regardless of dir.
            exec qs-overview toggle
            ;;
    esac
fi

# SECONDARY (legacy / future): hyprexpo plugin. Upstream-blocked on Arch
# hyprland 0.54.3-4 (ABI hash mismatch after May 4 2026 lib upgrade;
# rebuilds emit "[he] Version mismatch"). When 0.54.3-5 lands and
# hyprexpo is reinstalled, this branch reactivates automatically.
# TERTIARY: omarchy-window-switcher (text-list emergency only).
if ! hyprctl plugin list 2>/dev/null | grep -q hyprexpo; then
    case "$dir" in
        up)
            log "no overview daemon and no hyprexpo -> omarchy-window-switcher"
            exec omarchy-window-switcher
            ;;
        down)
            log "no overview daemon and no hyprexpo on DOWN -> scratchpad"
            exec hyprctl dispatch togglespecialworkspace scratchpad
            ;;
    esac
fi

state=$(cat "$STATE" 2>/dev/null || echo "CLOSED")
log "current state=$state"

case "$dir" in
    up)
        if [ "$state" = "OPEN" ]; then
            log "UP from OPEN -> dispatch off (toggle back to focused)"
            out=$(hyprctl dispatch hyprexpo:expo off 2>&1)
            rc=$?
            log "rc=$rc out='$out'"
            [ "$rc" -eq 0 ] && echo CLOSED > "$STATE"
        else
            log "UP from CLOSED -> dispatch on (open overview)"
            out=$(hyprctl dispatch hyprexpo:expo on 2>&1)
            rc=$?
            log "rc=$rc out='$out'"
            [ "$rc" -eq 0 ] && echo OPEN > "$STATE"
        fi
        ;;
    down)
        if [ "$state" = "OPEN" ]; then
            log "DOWN from OPEN -> dismiss overview (macOS-style return)"
            out=$(hyprctl dispatch hyprexpo:expo off 2>&1)
            rc=$?
            log "rc=$rc out='$out'"
            [ "$rc" -eq 0 ] && echo CLOSED > "$STATE"
        else
            log "DOWN from CLOSED -> togglespecialworkspace scratchpad"
            out=$(hyprctl dispatch togglespecialworkspace scratchpad 2>&1)
            rc=$?
            log "rc=$rc out='$out'"
        fi
        ;;
    *)
        log "ERROR: unknown dir=$dir (expected up|down)"
        exit 2
        ;;
esac

log "END"
