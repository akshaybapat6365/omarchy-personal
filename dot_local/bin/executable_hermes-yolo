#!/usr/bin/env bash
# Fast, readable Hermes TUI in YOLO mode for normal terminal launches.
set -euo pipefail

export HERMES_TUI=1
export HERMES_TUI_THEME=dark
export HERMES_TUI_DIR="${HERMES_TUI_DIR:-$HOME/.hermes/hermes-agent/ui-tui}"
export HERMES_REDACT_SECRETS="${HERMES_REDACT_SECRETS:-true}"
export TERM="${TERM:-xterm-256color}"
export COLORTERM="${COLORTERM:-truecolor}"

exec hermes --tui --yolo "$@"
