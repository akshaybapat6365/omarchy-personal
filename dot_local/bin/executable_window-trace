#!/usr/bin/env bash
# window-trace -- subscribe to Hyprland's openwindow/movewindow event stream
# and log every new window with: workspace it landed on vs active workspace
# at map time, class, title, PID, parent PID, parent process name, and
# (when present) XDG_ACTIVATION_TOKEN.
#
# Run interactively in a terminal when reproducing a placement bug:
#     window-trace
# Then trigger the misbehaving launch (e.g. press Super+Return on ws3, or
# have codex spawn a child app). Each event prints one line; ctrl-C to stop.
#
# Output columns are tab-separated for easy `column -t -s $'\t'` post-proc.

set -euo pipefail
SOCK="${XDG_RUNTIME_DIR:?}/hypr/$(hyprctl -j instances 2>/dev/null | jq -r '.[0].instance')/.socket2.sock"
[[ -S "$SOCK" ]] || { echo "No Hyprland event socket at $SOCK" >&2; exit 1; }

printf 'time\tevent\tactive_ws\tplaced_ws\taddr\tpid\tppid\tparent_proc\tclass\ttitle\n'

socat -u "UNIX-CONNECT:$SOCK" - | while IFS=">>" read -r evt rest; do
    case "$evt" in
        openwindow)
            # rest payload: ADDRESS,WORKSPACE_NAME,CLASS,TITLE
            addr=$(echo "$rest"  | awk -F, '{print $1}' | sed 's/^>//')
            wsn=$(echo  "$rest"  | awk -F, '{print $2}')
            cls=$(echo  "$rest"  | awk -F, '{print $3}')
            ttl=$(echo  "$rest"  | awk -F, '{print substr($0, index($0,$4))}')
            cur=$(hyprctl activeworkspace -j 2>/dev/null | jq -r .name)
            client=$(hyprctl clients -j 2>/dev/null | jq -r --arg a "0x$addr" '.[] | select(.address==$a)')
            pid=$(echo "$client" | jq -r .pid)
            ppid=$(awk '/^PPid:/{print $2}' "/proc/$pid/status" 2>/dev/null || echo "?")
            pproc=$(cat "/proc/$ppid/comm" 2>/dev/null || echo "?")
            printf '%s\topenwindow\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
                "$(date +%H:%M:%S.%3N)" "$cur" "$wsn" "$addr" "$pid" "$ppid" "$pproc" "$cls" "$ttl"
            ;;
    esac
done
