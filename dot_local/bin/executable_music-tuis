#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  music-tuis
  music-tuis platform
  music-tuis search "song or artist"
  music-tuis controls
  music-tuis ncmpcpp
  music-tuis visualizer
  music-tuis rmpc
  music-tuis rmpc-search "song or artist"
  music-tuis ytm
  music-tuis ytm-setup
  music-tuis ymc
  music-tuis ytui
  music-tuis ytermusic
  music-tuis cava

Players:
  platform     Integrated MPD player, streaming search, controls, visualizer
  search       No-login YouTube search that streams into MPD
  controls     Visible MPD transport controls
  ncmpcpp      MPD player UI with built-in controls and visualizer
  visualizer   MPD visualizer screen
  rmpc         rmpc frontend for MPD
  rmpc-search  Legacy alias for no-login streaming search
  ytm          ytm-player, requires account setup
  ytm-setup    Run ytm-player authentication wizard
  ymc          youtube-music-cli, third-party experimental client
  ytui         ytui-music
  ytermusic    ytermusic
  cava         CAVA visualizer, kept as optional fallback
USAGE
}

pick() {
  printf '%s\n' platform search controls ncmpcpp visualizer ytm ytm-setup ymc ytui ytermusic rmpc | fzf --prompt='music tui> '
}

run_or_hold() {
  "$@"
  code=$?
  if [[ "$code" -ne 0 ]]; then
    printf '\nCommand failed with exit code %s: %q' "$code" "$1"
    shift || true
    for arg in "$@"; do
      printf ' %q' "$arg"
    done
    printf '\n'
  fi
  printf '\nPress Enter to close...'
  read -r _ || true
  exit "$code"
}

cmd="${1:-}"
if [[ -z "${cmd}" ]]; then
  if command -v fzf >/dev/null 2>&1; then
    cmd="$(pick)"
  else
    usage
    exit 0
  fi
else
  shift || true
fi

case "${cmd}" in
  platform)
    exec music-platform
    ;;
  search)
    exec music-search-stream --hold "$@"
    ;;
  controls)
    exec music-controls
    ;;
  ncmpcpp)
    systemctl --user start mpd.service
    exec ncmpcpp --config /home/akshaybapat/.config/ncmpcpp/config
    ;;
  visualizer)
    systemctl --user start mpd.service
    exec ncmpcpp --config /home/akshaybapat/.config/ncmpcpp/config --screen visualizer
    ;;
  rmpc)
    systemctl --user start mpd.service
    exec rmpc
    ;;
  rmpc-search)
    systemctl --user start mpd.service
    query="${*:-}"
    exec music-search-stream --hold "${query}"
    ;;
  ytm)
    run_or_hold ytm
    ;;
  ytm-setup)
    run_or_hold ytm setup
    ;;
  ymc)
    run_or_hold youtube-music-cli
    ;;
  ytui)
    run_or_hold ytui_music run
    ;;
  ytermusic)
    run_or_hold ytermusic
    ;;
  cava)
    printf 'CAVA is disabled here because it crashed in this environment.\n'
    printf 'Use: music-tuis visualizer\n'
    printf '\nPress Enter to close...'
    read -r _ || true
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    printf 'Unknown player: %s\n\n' "${cmd}" >&2
    usage
    exit 2
    ;;
esac
