#!/usr/bin/env bash
set -euo pipefail

URL="http://127.0.0.1:11470/"
HEALTH="http://127.0.0.1:11470/heartbeat"
UNIT="stremio-service.service"

# Keep this hidden fallback from fighting the native Stremio shell.
if pgrep -af "$HOME/.local/opt/stremio-native/stremio" >/dev/null && curl -fsS "$HEALTH" >/dev/null 2>&1; then
  notify-send "Stremio" "Native Stremio is already running. Close it before using the web fallback." 2>/dev/null || true
  exit 1
fi

# Keep systemd as the single owner/supervisor of the hardened fallback service.
systemctl --user start "$UNIT"

for _ in $(seq 1 40); do
  if curl -fsS "$HEALTH" >/dev/null 2>&1; then
    break
  fi
  sleep 0.25
done

if ! curl -fsS "$HEALTH" >/dev/null 2>&1; then
  notify-send "Stremio" "Local Stremio service did not become healthy." 2>/dev/null || true
  exit 1
fi

# App-mode browser window: no manual localhost typing, no unmanaged service spawn.
if [[ "${1:-}" == "--check" ]]; then
  echo "Stremio service healthy at $HEALTH"
  exit 0
elif command -v chromium >/dev/null 2>&1; then
  nohup chromium --app="$URL" >/dev/null 2>&1 &
else
  nohup xdg-open "$URL" >/dev/null 2>&1 &
fi

exit 0
