#!/usr/bin/env bash
# omarchy-spend — unified AI spend launcher
# Usage: omarchy-spend [--vision {mission,demoscene,time,cycle}] [--print] [--waybar PROVIDER] [--frame] [--daemon]
set -euo pipefail

export PATH="$HOME/.local/share/mise/installs/node/25.9.0/bin:$HOME/.local/bin:/usr/local/bin:/usr/bin:/bin:${PATH:-}"

MISE_NODE_BIN="$HOME/.local/share/mise/installs/node/25.9.0/bin"
STATE_DIR="$HOME/.local/share/omarchy-spend/state"
STATE_JSON="$STATE_DIR/state.json"
STATE_EXAMPLE="$STATE_DIR/state.example.json"
CONFIG_DIR="$HOME/.config/omarchy-spend"
CONFIG_TOML="$CONFIG_DIR/config.toml"
VALID_VISIONS="mission demoscene time cycle"

# ---------------------------------------------------------------------------
# helpers
# ---------------------------------------------------------------------------

die() { printf '%s\n' "$*" >&2; exit 1; }

vision_bin() {
    local v="$1"
    case "$v" in
        mission)   echo "$HOME/.local/share/omarchy-spend/bin/omarchy-spend-mission" ;;
        demoscene) echo "$HOME/.local/share/omarchy-spend/bin/omarchy-spend-demoscene" ;;
        time)      echo "$HOME/.local/share/omarchy-spend/bin/omarchy-spend-time" ;;
        *)         die "unknown vision: $v" ;;
    esac
}

read_config_vision() {
    # Parse last_vision from config.toml with pure bash/awk
    if [[ -f "$CONFIG_TOML" ]]; then
        awk -F'=' '/^\s*last_vision\s*=/ {gsub(/[" \t]/, "", $2); print $2; exit}' "$CONFIG_TOML"
    fi
}

write_config_vision() {
    local v="$1"
    mkdir -p "$CONFIG_DIR"
    if [[ -f "$CONFIG_TOML" ]]; then
        # Update in-place
        awk -v val="\"$v\"" 'BEGIN{done=0} /^\s*last_vision\s*=/{if(!done){print "last_vision = "val; done=1; next}} {print}' \
            "$CONFIG_TOML" > "${CONFIG_TOML}.tmp" && mv "${CONFIG_TOML}.tmp" "$CONFIG_TOML"
    else
        # Create minimal config
        cat > "$CONFIG_TOML" <<TOML
[ui]
last_vision = "$v"
[refresh]
interval_seconds = 60
[budget]
monthly = 6000.0
alert_at_pct = 80
[openrouter]
api_key_env = "OPENROUTER_API_KEY"
TOML
    fi
}

cycle_vision() {
    # floor(unix_hour / 12) % 3 → index into {mission,demoscene,time}
    local hr
    hr=$(date -u +%H)
    local idx=$(( (hr / 12) % 3 ))
    case "$idx" in
        0) echo "mission" ;;
        1) echo "demoscene" ;;
        2) echo "time" ;;
    esac
}

resolve_vision() {
    local v="${1:-}"
    if [[ -z "$v" ]]; then
        v=$(read_config_vision)
        [[ -z "$v" ]] && v="mission"
    fi
    echo "$v"
}

validate_vision() {
    local v="$1"
    for valid in $VALID_VISIONS; do
        [[ "$v" == "$valid" ]] && return 0
    done
    die "Invalid vision '$v'. Must be one of: $VALID_VISIONS"
}

# ---------------------------------------------------------------------------
# --waybar PROVIDER
# ---------------------------------------------------------------------------

cmd_waybar() {
    local provider="$1"
    # Load state.json; fall back to state.example.json
    local state_file
    if [[ -f "$STATE_JSON" ]]; then
        state_file="$STATE_JSON"
    elif [[ -f "$STATE_EXAMPLE" ]]; then
        state_file="$STATE_EXAMPLE"
    else
        printf '{"text":"N/A","tooltip":"No state file","class":"quiet"}\n'
        return
    fi

    python3 - "$state_file" "$provider" <<'PY'
import json, sys, math

state_file, provider = sys.argv[1], sys.argv[2]
with open(state_file) as f:
    state = json.load(f)

providers = state.get("providers", {})
agg = state.get("aggregates", {})

if provider not in providers:
    print(json.dumps({"text": "N/A", "tooltip": f"Provider '{provider}' not found", "class": "quiet"}))
    sys.exit(0)

pdata = providers[provider]
today = pdata.get("today", 0.0)
lifetime = pdata.get("lifetime", 0.0)
month = pdata.get("month", 0.0)
today_total = agg.get("today_total", 0.0)

# Aggregates: burn rate, grade, budget
burn_rate = agg.get("burn_rate_per_hr", 0.0)
health_grade = agg.get("health_grade", "")
budget_used_pct = agg.get("budget_used_pct", 0.0)
budget_monthly = agg.get("budget_monthly", 0.0)
health_delta = agg.get("health_delta_wk", "")
session_count = agg.get("session_count_today", 0)
tokens_today = agg.get("tokens_today", 0)
forecast_eom = agg.get("forecast_eom", 0.0)

# Reset: minutes until next hour boundary (approximate daily reset heuristic)
import datetime
now = datetime.datetime.now()
mins_to_reset = 60 - now.minute
reset_str = f"{mins_to_reset}m" if mins_to_reset < 60 else "1h 0m"

# TPM estimate from tokens_today and hours elapsed
hours_elapsed = now.hour + now.minute / 60.0
tpm = int(tokens_today / max(hours_elapsed * 60, 1)) if tokens_today else 0

# Cache hit from provider data (not always present)
cache_hit_pct = pdata.get("cache_hit_pct", None)

# Budget bar (10 chars)
filled = min(10, int(budget_used_pct * 10))
budget_bar = "█" * filled + "░" * (10 - filled)
budget_display = f"{budget_used_pct * 100:.0f}%"

# Health delta human label
delta_map = {
    "up_from_a": "up from A", "up_from_b": "up from B", "up_from_c": "up from C",
    "down_from_a": "down from A", "down_from_b": "down from B", "down_from_c": "down from C",
    "stable": "stable",
}
delta_label = delta_map.get(health_delta, health_delta.replace("_", " ") if health_delta else "")

# class: quiet | warm | hot driven by burn rate + budget combined
if burn_rate > 5.0 or budget_used_pct > 0.80:
    cls = "hot"
    alt = "burn_high"
elif burn_rate >= 1.0 or budget_used_pct >= 0.50:
    cls = "warm"
    alt = "burn_mid"
else:
    cls = "quiet"
    alt = "burn_low"

# Text: today spend + burn rate + grade
grade_part = f" · {health_grade}" if health_grade else ""
text = f"${today:.2f} · ${burn_rate:.2f}/hr{grade_part}"

# Tooltip
tooltip_lines = [
    f"{provider.upper()} today: ${today:.2f}",
    f"Burn: ${burn_rate:.2f}/hr · {tpm} tpm",
]
if health_grade:
    grade_line = f"Grade: {health_grade}"
    if delta_label:
        grade_line += f" ({delta_label} last wk)"
    tooltip_lines.append(grade_line)
tooltip_lines.append(f"Budget: {budget_bar} {budget_display}")
tooltip_lines.append(f"Reset: {reset_str}")
if cache_hit_pct is not None:
    tooltip_lines.append(f"Cache hit: {int(cache_hit_pct * 100)}%")
tooltip_lines.append("")
if session_count:
    tooltip_lines.append(f"{session_count} sessions active")

models = pdata.get("models", [])
if models:
    tooltip_lines.append("Models:")
    for m in models[:3]:
        tooltip_lines.append(f"  {m['name']}: ${m.get('today', 0):.2f}")

tooltip = "\n".join(tooltip_lines)
print(json.dumps({"text": text, "tooltip": tooltip, "class": cls, "alt": alt}))
PY
}

# ---------------------------------------------------------------------------
# --ambient  (Hyprland floating widget)
# ---------------------------------------------------------------------------

cmd_ambient() {
    local state_file
    if [[ -f "$STATE_JSON" ]]; then
        state_file="$STATE_JSON"
    elif [[ -f "$STATE_EXAMPLE" ]]; then
        state_file="$STATE_EXAMPLE"
    else
        state_file=""
    fi

    python3 - "$state_file" <<'PY'
import sys, json, os, time, threading

STATE_FILE = sys.argv[1] if len(sys.argv) > 1 else ""

# ── State reader ────────────────────────────────────────────────────────────
def read_state():
    if not STATE_FILE or not os.path.exists(STATE_FILE):
        return {}
    try:
        with open(STATE_FILE) as f:
            return json.load(f)
    except Exception:
        return {}

def extract(state):
    agg = state.get("aggregates", {})
    burn = agg.get("burn_rate_per_hr", 0.0)
    grade = agg.get("health_grade", "?")
    budget_pct = agg.get("budget_used_pct", 0.0)
    sessions = agg.get("session_count_today", 0)
    tokens = agg.get("tokens_today", 0)
    cache = None  # not always present at agg level

    import datetime
    now = datetime.datetime.now()
    hours_elapsed = now.hour + now.minute / 60.0
    tpm = int(tokens / max(hours_elapsed * 60, 1)) if tokens else 0
    mins_to_reset = 60 - now.minute
    reset_str = f"{mins_to_reset // 60}:{mins_to_reset % 60:02d}" if mins_to_reset >= 60 else f"0:{mins_to_reset:02d}"

    # class
    if burn > 5.0 or budget_pct > 0.80:
        cls = "hot"
    elif burn >= 1.0 or budget_pct >= 0.50:
        cls = "warm"
    else:
        cls = "quiet"

    budget_bar_filled = min(10, int(budget_pct * 10))
    budget_bar = "█" * budget_bar_filled + "░" * (10 - budget_bar_filled)

    pages = [
        f"🔥 ${burn:.2f}/hr · {int(budget_pct*100)}%",
        f"Grade: {grade} · {sessions} sess · {reset_str} reset",
        f"{budget_bar} {int(budget_pct*100)}% · {tpm} tpm",
    ]
    return {"cls": cls, "pages": pages, "burn": burn, "budget_pct": budget_pct}

# ── Color map ────────────────────────────────────────────────────────────────
COLORS = {
    "quiet": {"bg": "#0a0610", "fg": "#e5dfd9"},
    "warm":  {"bg": "#767f59", "fg": "#000000"},
    "hot":   {"bg": "#805f4a", "fg": "#e5dfd9"},
}

# ── Try GTK4 first, fall back to tkinter ────────────────────────────────────
def run_gtk(data_ref, lock):
    import gi
    gi.require_version("Gtk", "4.0")
    from gi.repository import Gtk, GLib

    class AmbientWindow(Gtk.ApplicationWindow):
        def __init__(self, app):
            super().__init__(application=app)
            self.set_title("omarchy-spend-ambient")
            self.set_default_size(200, 80)
            self.set_resizable(False)
            self._page = 0
            self._label = Gtk.Label()
            self._label.set_wrap(False)
            self._label.set_justify(Gtk.Justification.CENTER)
            self.set_child(self._label)
            self._update_display()
            # Cycle page every 3s
            GLib.timeout_add(3000, self._cycle_page)
            # Refresh data every 5s
            GLib.timeout_add(5000, self._refresh_data)
            # Key handler
            key_ctrl = Gtk.EventControllerKey()
            key_ctrl.connect("key-pressed", self._on_key)
            self.add_controller(key_ctrl)
            # Click handler
            click_ctrl = Gtk.GestureClick()
            click_ctrl.connect("pressed", self._on_click)
            self.add_controller(click_ctrl)

        def _get_data(self):
            with lock:
                return dict(data_ref[0])

        def _update_display(self):
            d = self._get_data()
            pages = d.get("pages", ["Loading..."])
            page_text = pages[self._page % len(pages)]
            self._label.set_markup(page_text.replace("&", "&amp;"))
            cls = d.get("cls", "quiet")
            c = COLORS.get(cls, COLORS["quiet"])
            # Apply CSS
            css = f"""
            window {{ background-color: {c['bg']}; }}
            label {{ color: {c['fg']}; font-family: 'JetBrainsMono Nerd Font'; font-size: 11px; padding: 8px; }}
            """
            provider = Gtk.CssProvider()
            provider.load_from_data(css.encode())
            self.get_style_context().add_provider(provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
            self._label.get_style_context().add_provider(provider, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        def _cycle_page(self):
            self._page += 1
            self._update_display()
            return True  # keep repeating

        def _refresh_data(self):
            new_state = read_state()
            new_d = extract(new_state)
            with lock:
                data_ref[0] = new_d
            self._update_display()
            return True

        def _on_key(self, ctrl, keyval, keycode, state):
            from gi.repository import Gdk
            if keyval == Gdk.KEY_Escape:
                self.close()
            return False

        def _on_click(self, ctrl, n, x, y):
            self.close()
            os.system("omarchy-spend &")

    def on_activate(app):
        win = AmbientWindow(app)
        win.present()

    app = Gtk.Application(application_id="org.omarchy.spend.ambient")
    app.connect("activate", on_activate)
    app.run([])

def run_tk(data_ref, lock):
    import tkinter as tk

    root = tk.Tk()
    root.title("omarchy-spend-ambient")
    root.geometry("200x80")
    root.resizable(False, False)
    root.wm_attributes("-topmost", True)
    root.overrideredirect(False)

    label = tk.Label(root, font=("monospace", 10), justify="center", wraplength=190)
    label.pack(expand=True, fill="both", padx=8, pady=8)

    page_ref = [0]

    def update_display():
        with lock:
            d = dict(data_ref[0])
        pages = d.get("pages", ["Loading..."])
        text = pages[page_ref[0] % len(pages)]
        cls = d.get("cls", "quiet")
        c = COLORS.get(cls, COLORS["quiet"])
        root.configure(bg=c["bg"])
        label.configure(text=text, bg=c["bg"], fg=c["fg"])

    def cycle_page():
        page_ref[0] += 1
        update_display()
        root.after(3000, cycle_page)

    def refresh_data():
        new_state = read_state()
        new_d = extract(new_state)
        with lock:
            data_ref[0] = new_d
        update_display()
        root.after(5000, refresh_data)

    def on_click(event):
        root.destroy()
        os.system("omarchy-spend &")

    def on_esc(event):
        root.destroy()

    label.bind("<Button-1>", on_click)
    root.bind("<Escape>", on_esc)

    update_display()
    root.after(3000, cycle_page)
    root.after(5000, refresh_data)
    root.mainloop()

# ── Main ─────────────────────────────────────────────────────────────────────
state = read_state()
data = extract(state)
lock = threading.Lock()
data_ref = [data]

try:
    import gi
    gi.require_version("Gtk", "4.0")
    from gi.repository import Gtk
    run_gtk(data_ref, lock)
except Exception:
    run_tk(data_ref, lock)
PY
}

# ---------------------------------------------------------------------------
# --frame
# ---------------------------------------------------------------------------

cmd_frame() {
    local vision
    vision=$(resolve_vision "")
    [[ "$vision" == "cycle" ]] && vision=$(cycle_vision)
    local frame_file="$STATE_DIR/frame-${vision}.ansi"

    if [[ -f "$frame_file" ]]; then
        cat "$frame_file"
        return
    fi

    # Frame missing — run prefetch synchronously once if prefetch bin exists
    local prefetch_bin="$HOME/.local/bin/omarchy-spend-prefetch"
    if [[ -x "$prefetch_bin" ]]; then
        "$prefetch_bin" 2>/dev/null || true
    fi

    # Try again after prefetch
    if [[ -f "$frame_file" ]]; then
        cat "$frame_file"
        return
    fi

    # Hardcoded minimal fallback frame
    local today_total="N/A"
    local state_file
    if [[ -f "$STATE_JSON" ]]; then
        state_file="$STATE_JSON"
    elif [[ -f "$STATE_EXAMPLE" ]]; then
        state_file="$STATE_EXAMPLE"
    fi
    if [[ -n "${state_file:-}" ]]; then
        today_total=$(python3 -c "import json; d=json.load(open('$state_file')); print(f\"\${d['aggregates']['today_total']:.2f}\")" 2>/dev/null || echo "N/A")
    fi

    printf '\033[1;36m╔══════════════════════════════════════════════════════════════════════════════╗\033[0m\n'
    printf '\033[1;36m║\033[0m  \033[1;37mAI SPEND DASHBOARD\033[0m  ·  vision: \033[1;33m%-10s\033[0m  ·  today: \033[1;32m%-10s\033[0m            \033[1;36m║\033[0m\n' "$vision" "$today_total"
    printf '\033[1;36m║\033[0m  \033[0;90m(frame not yet rendered — run omarchy-spend-prefetch to build frames)\033[0m       \033[1;36m║\033[0m\n'
    printf '\033[1;36m╚══════════════════════════════════════════════════════════════════════════════╝\033[0m\n'
}

# ---------------------------------------------------------------------------
# --print
# ---------------------------------------------------------------------------

cmd_print() {
    local vision
    vision=$(resolve_vision "")
    [[ "$vision" == "cycle" ]] && vision=$(cycle_vision)
    local frame_file="$STATE_DIR/frame-${vision}.ansi"
    if [[ -f "$frame_file" ]]; then
        cat "$frame_file"
    else
        cmd_frame
    fi
}

# ---------------------------------------------------------------------------
# --daemon
# ---------------------------------------------------------------------------

cmd_daemon() {
    local vision="$1"
    local session_name="ai-spend"
    if tmux has-session -t "$session_name" 2>/dev/null; then
        printf 'tmux session "%s" already exists — skipping\n' "$session_name"
        return
    fi
    local bin
    bin=$(vision_bin "$vision")
    if [[ ! -x "$bin" ]]; then
        die "Vision binary not found or not executable: $bin"
    fi
    tmux new-session -d -s "$session_name" "$bin"
    printf 'Started tmux session "%s" with vision %s\n' "$session_name" "$vision"
}

# ---------------------------------------------------------------------------
# launch vision in alacritty
# ---------------------------------------------------------------------------

launch_vision() {
    local vision="$1"
    local bin
    bin=$(vision_bin "$vision")
    if [[ ! -x "$bin" ]]; then
        die "Vision binary not found or not executable: $bin\nRun the build step for the '$vision' vision first."
    fi
    exec alacritty --class ai-spend --title "AI Spend" --hold -e "$bin"
}

# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

VISION_ARG=""
DO_PRINT=false
DO_FRAME=false
DO_DAEMON=false
DO_AMBIENT=false
WAYBAR_PROVIDER=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --vision)
            [[ $# -lt 2 ]] && die "--vision requires an argument"
            VISION_ARG="$2"; shift 2 ;;
        --print)
            DO_PRINT=true; shift ;;
        --frame)
            DO_FRAME=true; shift ;;
        --daemon)
            DO_DAEMON=true; shift ;;
        --ambient)
            DO_AMBIENT=true; shift ;;
        --waybar)
            [[ $# -lt 2 ]] && die "--waybar requires PROVIDER argument"
            WAYBAR_PROVIDER="$2"; shift 2 ;;
        -h|--help)
            cat <<HELP
Usage: omarchy-spend [OPTIONS]

Options:
  --vision {mission,demoscene,time,cycle}  Select/persist vision
  --print                                  Print frame to stdout and exit
  --frame                                  Hot-path: cat cached frame and exit
  --waybar PROVIDER                        Emit Waybar JSON for provider
  --ambient                                Spawn Hyprland floating ambient widget
  --daemon                                 Keep tmux session ai-spend warm
  -h, --help                               Show this help

Providers for --waybar: claude codex opencode openrouter
HELP
            exit 0 ;;
        *)
            die "Unknown argument: $1" ;;
    esac
done

# --waybar takes priority (used by Waybar config)
if [[ -n "$WAYBAR_PROVIDER" ]]; then
    cmd_waybar "$WAYBAR_PROVIDER"
    exit 0
fi

# --ambient: spawn floating widget
if $DO_AMBIENT; then
    cmd_ambient
    exit 0
fi

# --frame: hot-path
if $DO_FRAME; then
    cmd_frame
    exit 0
fi

# --print
if $DO_PRINT; then
    cmd_print
    exit 0
fi

# Resolve and validate vision
if [[ -n "$VISION_ARG" ]]; then
    validate_vision "$VISION_ARG"
    if [[ "$VISION_ARG" == "cycle" ]]; then
        RESOLVED=$(cycle_vision)
    else
        RESOLVED="$VISION_ARG"
    fi
    write_config_vision "$VISION_ARG"
else
    RESOLVED=$(read_config_vision)
    [[ -z "$RESOLVED" ]] && RESOLVED="mission"
    [[ "$RESOLVED" == "cycle" ]] && RESOLVED=$(cycle_vision)
fi

# --daemon
if $DO_DAEMON; then
    cmd_daemon "$RESOLVED"
    exit 0
fi

# Default: launch alacritty
launch_vision "$RESOLVED"
