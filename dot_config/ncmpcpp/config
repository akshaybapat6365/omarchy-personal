mpd_host = "/home/akshaybapat/.local/state/mpd/socket"
mpd_port = "6600"

startup_screen = "playlist"
startup_slave_screen = "visualizer"
user_interface = "alternative"
alternative_header_first_line_format = "$b$3{%t}|{%f}$9$/b"
alternative_header_second_line_format = "{$5%a$9}{  $7%b$9}{  $6%y$9}"

playlist_display_mode = "columns"
song_columns_list_format = "(6f)[blue]{l} (28)[cyan]{a} (48)[white]{t|f} (18)[magenta]{b}"
playlist_show_remaining_time = "yes"
playlist_shorten_total_times = "yes"
playlist_separate_albums = "no"

browser_display_mode = "columns"
search_engine_display_mode = "columns"
display_bitrate = "yes"
external_editor = "nvim"
message_delay_time = "1"
mouse_support = "yes"
header_visibility = "yes"
titles_visibility = "yes"
statusbar_visibility = "yes"

progressbar_look = "=> "
progressbar_color = "black:b"
progressbar_elapsed_color = "green:b"
state_line_color = "blue"
state_flags_color = "cyan:b"
main_window_color = "white"
current_item_prefix = "$(cyan)$r"
current_item_suffix = "$/r$(end)"
current_item_inactive_column_prefix = "$(cyan)$r"
current_item_inactive_column_suffix = "$/r$(end)"

visualizer_data_source = "/home/akshaybapat/.local/state/mpd/mpd.fifo"
visualizer_output_name = "Visualizer feed"
visualizer_in_stereo = "yes"
visualizer_type = "spectrum"
visualizer_fps = "60"
visualizer_autoscale = "yes"
visualizer_look = "||"
visualizer_color = "blue, cyan, green, yellow, magenta, red"
visualizer_spectrum_smooth_look = "yes"
visualizer_spectrum_dft_size = "3"
visualizer_spectrum_gain = "8"
visualizer_spectrum_hz_min = "35"
visualizer_spectrum_hz_max = "16000"
visualizer_spectrum_log_scale_x = "yes"
visualizer_spectrum_log_scale_y = "yes"
