# Application bindings
bindd = SUPER, RETURN, Terminal, exec, uwsm-app -- xdg-terminal-exec --dir="$(omarchy-cmd-terminal-cwd)"
bindd = SUPER ALT, RETURN, Tmux, exec, uwsm-app -- xdg-terminal-exec --dir="$(omarchy-cmd-terminal-cwd)" bash -c "tmux attach || tmux new -s Work"
bindd = SUPER SHIFT, RETURN, Browser, exec, omarchy-launch-browser
bindd = SUPER SHIFT, F, File manager, exec, uwsm-app -- nautilus --new-window
bindd = SUPER ALT SHIFT, F, File manager (cwd), exec, uwsm-app -- nautilus --new-window "$(omarchy-cmd-terminal-cwd)"
bindd = SUPER SHIFT, B, Browser, exec, omarchy-launch-browser
bindd = SUPER SHIFT ALT, B, Browser (private), exec, omarchy-launch-browser --private
bindd = SUPER SHIFT, M, Music, exec, omarchy-launch-or-focus spotify
bindd = SUPER, M, Music platform, exec, /home/akshaybapat/.local/bin/music-platform-launch
bindd = SUPER ALT, M, Music platform, exec, /home/akshaybapat/.local/bin/music-platform-launch
bindd = SUPER CTRL, M, Music platform, exec, /home/akshaybapat/.local/bin/music-platform-launch
bindd = SUPER CTRL ALT, M, Music platform, exec, /home/akshaybapat/.local/bin/music-platform-launch
bindd = SUPER SHIFT ALT, M, Stop all music, exec, /home/akshaybapat/.local/bin/music-stop
bindd = SUPER SHIFT, N, Editor, exec, omarchy-launch-editor
bindd = SUPER SHIFT, D, Docker, exec, omarchy-launch-tui lazydocker
bindd = SUPER SHIFT, G, Signal, exec, omarchy-launch-or-focus ^signal$ "uwsm-app -- signal-desktop"
bindd = SUPER SHIFT, O, Obsidian, exec, omarchy-launch-or-focus ^obsidian$ "uwsm-app -- obsidian -disable-gpu --enable-wayland-ime"
bindd = SUPER SHIFT, W, Typora, exec, uwsm-app -- typora --enable-wayland-ime
bindd = SUPER SHIFT, SLASH, Passwords, exec, uwsm-app -- 1password

# If your web app url contains #, type it as ## to prevent hyprland treating it as a comment
bindd = SUPER SHIFT, A, Codex, exec, uwsm-app -- xdg-terminal-exec --dir="$(omarchy-cmd-terminal-cwd)" codex
bindd = SUPER SHIFT ALT, A, Claude Code, exec, uwsm-app -- xdg-terminal-exec --dir="$(omarchy-cmd-terminal-cwd)" claude
bindd = SUPER SHIFT, C, Calendar, exec, omarchy-launch-webapp "https://app.hey.com/calendar/weeks/"
bindd = SUPER SHIFT, E, Email, exec, omarchy-launch-webapp "https://app.hey.com"
bindd = SUPER SHIFT, Y, YouTube, exec, omarchy-launch-webapp "https://youtube.com/"
bindd = SUPER ALT, Y, ytm-player, exec, alacritty --class org.omarchy.ytm-player --title ytm-player -e /home/akshaybapat/.local/bin/music-tuis ytm
bindd = SUPER CTRL ALT, Y, YouTube Music CLI, exec, alacritty --class org.omarchy.youtube-music-cli --title youtube-music-cli -e /home/akshaybapat/.local/bin/music-tuis ymc
bindd = SUPER SHIFT ALT, Y, ytermusic, exec, alacritty --class org.omarchy.ytermusic --title ytermusic -e /home/akshaybapat/.local/bin/music-tuis ytermusic
bindd = SUPER SHIFT ALT, G, WhatsApp, exec, omarchy-launch-or-focus-webapp WhatsApp "https://web.whatsapp.com/"
bindd = SUPER SHIFT CTRL, G, Google Messages, exec, omarchy-launch-or-focus-webapp "Google Messages" "https://messages.google.com/web/conversations"
bindd = SUPER SHIFT, P, Google Photos, exec, omarchy-launch-or-focus-webapp "Google Photos" "https://photos.google.com/"
bindd = SUPER SHIFT, X, X, exec, omarchy-launch-webapp "https://x.com/"
bindd = SUPER SHIFT ALT, X, X Post, exec, omarchy-launch-webapp "https://x.com/compose/post"

# Add extra bindings
# bind = SUPER SHIFT, R, exec, alacritty -e ssh your-server

# Hyprexpo: Mission Control / workspace overview (toggle on/off)
bindd = SUPER, grave, Workspace overview (hyprexpo), hyprexpo:expo, toggle

# ---- AI workflow ----
# Floating scratchpads — one per AI tool, persistent across workspaces
bindd = SUPER, BACKSLASH, AI scratchpad (Claude Code), exec, omarchy-ai-scratchpad claude
bindd = SUPER ALT, BACKSLASH, AI scratchpad (Codex), exec, omarchy-ai-scratchpad codex
bindd = SUPER SHIFT, BACKSLASH, AI scratchpad (opencode), exec, omarchy-ai-scratchpad opencode
# /ask Spotlight: prompt → claude --print → notification + clipboard
bindd = SUPER, PERIOD, AI quick ask, exec, omarchy-ask
# Floating Claude usage monitor (live token / rate-limit dashboard)
bindd = SUPER CTRL, U, Claude usage monitor, exec, alacritty --class ai-monitor --title ai-monitor -e claude-monitor
# Cross-CLI cost dashboard (Claude + Codex via ccusage)
bindd = SUPER CTRL, Y, Token cost session view, exec, alacritty --class ai-ccusage --title ai-ccusage -e ccusage session
# Skill picker — fzf over awesome-claude-code
bindd = SUPER CTRL, SLASH, AI skill picker, exec, alacritty --class ai-skill-picker --title ai-skill-picker -e omarchy-skill-picker
# Toggle the cheatsheet overlay (frosted-glass card layered above the wallpaper)
bindd = SUPER SHIFT, K, Toggle keybinds overlay, exec, omarchy-cheatsheet

# ---- AI window rules (Hyprland 0.53+: boolean actions need explicit 'on') ----
windowrule = workspace special:ai silent,          match:class ai-claude
windowrule = workspace special:ai-codex silent,    match:class ai-codex
windowrule = workspace special:ai-opencode silent, match:class ai-opencode
windowrule = float on,        match:class ai-(claude|codex|opencode)
windowrule = size 80% 80%,    match:class ai-(claude|codex|opencode)
windowrule = center on,       match:class ai-(claude|codex|opencode)
windowrule = opacity 0.95 0.92, match:class ai-(claude|codex|opencode)

# Common floating apps centered (calculator, color picker, 1Password)
windowrule = float on,  match:class (org.gnome.Calculator|hyprpicker|1Password)
windowrule = center on, match:class (org.gnome.Calculator|hyprpicker|1Password)

# /ask Spotlight overlay
windowrule = float on,      match:class ask-overlay
windowrule = center on,     match:class ask-overlay
windowrule = size 900 80,   match:class ask-overlay
windowrule = pin on,        match:class ask-overlay

# Floating monitor / picker windows
windowrule = float on,     match:class ai-(monitor|ccusage|skill-picker)
windowrule = center on,    match:class ai-(monitor|ccusage|skill-picker)
windowrule = size 70% 70%, match:class ai-(monitor|ccusage|skill-picker)

# ---- Live desktop widget (pinned to desktop layer via hyprwinwrap) ----
windowrule = float on,           match:class omarchy-widget
windowrule = pin on,             match:class omarchy-widget
windowrule = move 80 60,         match:class omarchy-widget
windowrule = size 460 700,       match:class omarchy-widget
# noborder/noinitialfocus aren't valid action names in Hyprland 0.54.3
# (workspace_rules format) — drop them; widget already has decorations=None via alacritty

# ---- Per-workspace app placement (auto-route apps to their home workspace) ----
windowrule = workspace 1 silent, match:class (chromium|chrome|google-chrome|firefox|brave-browser|Brave-browser)
windowrule = workspace 4 silent, match:class (signal|Slack|WhatsApp|discord)
windowrule = workspace 5 silent, match:class (Spotify|spotify)

# Music surface: current-workspace utility windows, not fixed-workspace apps.
windowrule = float on,          match:class org\.omarchy\.(music-platform|music-search|ytm-player|youtube-music-cli|ytermusic)
windowrule = size 1600 980,     match:class org\.omarchy\.music-platform
windowrule = size 1360 860,     match:class org\.omarchy\.(music-search|ytm-player|youtube-music-cli|ytermusic)
windowrule = center on,         match:class org\.omarchy\.(music-platform|music-search|ytm-player|youtube-music-cli|ytermusic)
windowrule = opacity 0.97 0.94, match:class org\.omarchy\.(music-platform|music-search|ytm-player|youtube-music-cli|ytermusic)

# ---- Open dashboard overlay (Super+H) ----
bindd = SUPER, H, Toggle live dashboard, exec, omarchy-dashboard

# Cheatsheet overlay — full-screen, page-level transparency in HTML.
# Hyprland window opacity stays at 1.0 so text remains fully opaque;
# the wallpaper bleed-through is achieved via CSS rgba() bg in the page.
windowrule = float on,            match:title OmarchyCheatsheetOverlay
windowrule = pin on,              match:title OmarchyCheatsheetOverlay
windowrule = size 1920 1174,      match:title OmarchyCheatsheetOverlay
windowrule = move 0 26,           match:title OmarchyCheatsheetOverlay

# Overwrite existing bindings, like putting Omarchy Menu on Super + Space
# unbind = SUPER, SPACE
# bindd = SUPER, SPACE, Omarchy menu, exec, omarchy-menu

